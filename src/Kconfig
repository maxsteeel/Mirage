config MIRAGE
	tristate "Mirage virtual filesystem support"
	help
	  A stackable filesystem for Android content redirection.

config MIRAGE_KERNEL_UMOUNT
	bool "Mirage kernel-level umount support"
	depends on MIRAGE
	default n
	help
	  Enable kernel-level automatic umount support for Mirage.
	  This allows Mirage to automatically unmount paths for app
	  processes without depending on KernelSU or other external
	  modules.

	  This feature hooks into the kernel's setuid/setresuid syscalls
	  to trigger umount operations when zygote forks app processes.

config MIRAGE_PROCFS
	bool "Mirage procfs interface for umount management"
	depends on MIRAGE_KERNEL_UMOUNT
	default y
	help
	  Enable procfs interface (/proc/mirage/) for managing the
	  kernel umount list from userspace.

	  This creates the following proc entries:
	  - /proc/mirage/umount_list   - List all umount paths
	  - /proc/mirage/umount_add    - Add a path to umount list
	  - /proc/mirage/umount_del    - Remove a path from umount list
	  - /proc/mirage/umount_clear  - Clear all umount paths
	  - /proc/mirage/umount_enabled - Enable/disable umount

	  If disabled, you can still manage the umount list via kernel
	  hooks or module parameters, but not from userspace at runtime.
